{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AccumulationWeights": {
    "VolumeWindow": 20,
    "CompressionWindow": 60,
    "CmfWindow": 20,
    "CmfSlopeWindow": 10,
    "ObvWindow": 20,
    "VwapWindow": 20,
    "WeightVolume": 0.25,
    "WeightCompression": 0.20,
    "WeightCmf": 0.30,
    "WeightCmfSlope": 0.10,
    "WeightObv": 0.10,
    "WeightVwap": 0.05,
    "LogisticK": 1.0,
    "VwapProximityPct": 0.03,
    "CompositeThresholdHigh": 70,
    "CompositeThresholdBreakout": 50,
    "CmfSignThreshold": 0.05,
    "MinHistoryBars": 70
  }
}
